{
  "$schema": "https://www.krakend.io/schema/v2.7/krakend.json",
  "version": 3,
  "name": "Ajudafio API Gateway",
  "timeout": "30s",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "endpoints": [
    {
      "endpoint": "/health",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/health",
          "host": ["http://api:8080"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/users",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users",
          "host": ["http://api:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/ajudafio/protocol/openid-connect/certs",
          "cache": true,
          "disable_jwk_security": true,
          "roles_key": "roles",
          "propagate_claims": [
            ["sub", "x-user-id"],
            ["email", "x-user-email"],
            ["preferred_username", "x-user-name"],
            ["roles", "x-user-roles"]
          ]
        }
      }
    },
    {
      "endpoint": "/api/users/{id}",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/{id}",
          "host": ["http://api:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/ajudafio/protocol/openid-connect/certs",
          "cache": true,
          "disable_jwk_security": true,
          "roles_key": "roles",
          "propagate_claims": [
            ["sub", "x-user-id"],
            ["email", "x-user-email"],
            ["preferred_username", "x-user-name"],
            ["roles", "x-user-roles"]
          ]
        }
      }
    },
    {
      "endpoint": "/api/users/{id}",
      "method": "PATCH",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/{id}",
          "host": ["http://api:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/ajudafio/protocol/openid-connect/certs",
          "cache": true,
          "disable_jwk_security": true,
          "roles_key": "roles",
          "propagate_claims": [
            ["sub", "x-user-id"],
            ["email", "x-user-email"],
            ["preferred_username", "x-user-name"],
            ["roles", "x-user-roles"]
          ]
        }
      }
    },
    {
      "endpoint": "/api/users/{id}",
      "method": "DELETE",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/{id}",
          "host": ["http://api:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/ajudafio/protocol/openid-connect/certs",
          "cache": true,
          "disable_jwk_security": true,
          "roles_key": "roles",
          "roles": ["ADMIN"],
          "propagate_claims": [
            ["sub", "x-user-id"],
            ["email", "x-user-email"],
            ["preferred_username", "x-user-name"],
            ["roles", "x-user-roles"]
          ]
        }
      }
    }
  ]
}
